{
  "manifest_version": 3,
  "name": "TopTeamTracker",
  "version": "2.0.0",
  "description": "Chọn listing từ Etsy và lưu vào TopTeamTracker để theo dõi",
  "permissions": ["tabs"],
  "host_permissions": [
    "https://*.etsy.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TopTeamTracker",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/search*", "https://www.etsy.com/?*", "https://www.etsy.com/"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
