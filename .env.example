# ─────────────────────────────────────────────────────────────────────────────
# EtsyPulse — Environment Variables
# Copy file này thành .env và điền thông tin thật
# ─────────────────────────────────────────────────────────────────────────────

# URL của web app (Vercel hoặc localhost khi dev)
ETSYPULSE_API_URL=https://your-app.vercel.app

# Supabase (lấy từ supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─────────────────────────────────────────────────────────────────────────────
# VPS Harvest Daemon
# ─────────────────────────────────────────────────────────────────────────────

# Số Playwright worker chạy song song (= số HeyEtsy seats bạn có)
N_WORKERS=3

# Đường dẫn tuyệt đối đến thư mục HeyEtsy extension đã unpack trên VPS
# Cách lấy extension từ Windows:
#   1. Mở Chrome → chrome://extensions/ → bật Developer Mode
#   2. Tìm HeyEtsy → copy Extension ID (vd: abcdefghijklmnopqrstuvwxyz123456)
#   3. Vào thư mục: C:\Users\[tên]\AppData\Local\Google\Chrome\User Data\Default\Extensions\[ID]\
#   4. Copy thư mục version mới nhất (vd: 2.1.0_0) lên VPS vào /root/etsypulse-web/heyetsy-extension/
#   5. Điền đường dẫn VPS vào đây:
HEYETSY_EXT_PATH=/root/etsypulse-web/heyetsy-extension

# Thư mục lưu Chrome profiles (mỗi worker 1 profile riêng)
PROFILES_DIR=/root/etsypulse-web/chrome-profiles

# Delay giữa 2 listing trong 1 worker (ms) — tránh bị Etsy block
DELAY_MS=5000

# Timeout chờ HeyEtsy widget load (ms)
HEYETSY_TIMEOUT_MS=12000

# Giờ chạy harvest tự động (múi giờ VPS, thường UTC)
# 2:00 AM UTC = 9:00 AM GMT+7 (Việt Nam)
HARVEST_HOUR=2
HARVEST_MINUTE=0

# ─────────────────────────────────────────────────────────────────────────────
# Kết nối VNC để setup profiles lần đầu (chỉ cần 1 lần)
# ─────────────────────────────────────────────────────────────────────────────
# Trên VPS, chạy:
#   x11vnc -display :99 -nopw -listen localhost -xkb &
#
# Trên máy Windows, dùng SSH tunnel:
#   ssh -L 5900:localhost:5900 root@[VPS_IP]
#
# Mở VNC Viewer (TigerVNC / RealVNC) → kết nối localhost:5900
# Sau đó chạy:
#   DISPLAY=:99 npm run harvest:setup
# Chrome sẽ mở trong cửa sổ VNC → đăng nhập HeyEtsy cho từng profile
